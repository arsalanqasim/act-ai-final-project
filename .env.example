# OpportunityPulse AI - Phase 1 Environment Configuration Template
# DO NOT include real production secrets in this file.
# Copy this file to .env locally or set these variables in Vercel Project Settings.

# -----------------------------------------------------------------------------
# 1. BROWSER / SUPABASE PUBLIC CONFIGURATION (Safe for VITE_ prefix)
# -----------------------------------------------------------------------------
# Public Supabase URL from Project Settings -> API
VITE_SUPABASE_URL=

# Public Supabase Anon (Public) Key from Project Settings -> API
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# 2. SERVER-ONLY BACKEND CONFIGURATION (NEVER expose to browser/VITE_)
# -----------------------------------------------------------------------------
# Server-side Supabase URL (used by Vercel Serverless Functions)
SUPABASE_URL=

# Server-side Supabase Anon Key (used by Vercel Serverless Functions)
SUPABASE_ANON_KEY=

# Google Gemini API Key for Server-Side AI Gateway
# CRITICAL: Must NEVER be given VITE_ prefix, stored in browser localStorage, or shipped to client bundles.
GEMINI_API_KEY=
